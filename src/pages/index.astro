---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sortedPosts = posts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const papers = await getCollection("papers", ({ data }: CollectionEntry<"papers">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sortedPapers = papers.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const projects = await getCollection("notes", ({ data }: CollectionEntry<"notes">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sortedProjects = projects.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const socialLinks = [
  { label: "GitHub", url: "https://github.com/GAD-cell" },
  { label: "LinkedIn", url: "https://www.linkedin.com/in/sinou%C3%A9-gad-98b7b324b/" },
  { label: "HuggingFace", url: "https://huggingface.co/GAD-cell" },
  { label: "Scholar", url: "https://scholar.google.com/citations?hl=en&user=R0zzGSsAAAAJ" },
];

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short" });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sinoué GAD</title>
    <meta name="description" content="Machine Learning Scientist" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <main>
      <div class="header">
        <img src="/images/pp_pro.png" alt="Sinoué GAD" class="avatar" />
        <div>
          <h1>Sinoué GAD</h1>
          <p class="subtitle">Machine Learning Scientist · MTS Intern at Liquid AI (post-training)</p>
        </div>
      </div>

      <p class="description">
        <!-- TODO: add your description here -->
        <em style="color: #999;"></em>
      </p>

      <p class="links">
        {socialLinks.map((link, i) => (
          <>
            <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
            {i < socialLinks.length - 1 && " · "}
          </>
        ))}
      </p>

      <p><a href="/CV_GAD.pdf" download class="resume-btn">Download CV</a></p>

      <hr />

      <section>
        <h2>Papers</h2>
        <ul>
          {sortedPapers.map((paper) => (
            <li>
              <a href={paper.data.pdfUrl} target="_blank" rel="noopener noreferrer">
                {paper.data.title}
              </a>
              {paper.data.conference && <span class="meta"> — {paper.data.conference}</span>}
              <span class="meta"> ({paper.data.publishedAt.getFullYear()})</span>
            </li>
          ))}
        </ul>
      </section>

      <hr />

      <section>
        <h2>Blog</h2>
        <ul>
          {sortedPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <span class="meta"> — {formatDate(post.data.publishedAt)}</span>
            </li>
          ))}
        </ul>
      </section>

      <hr />

      <section>
        <h2>Projects</h2>
        <ul>
          {sortedProjects.map((project) => (
            <li>
              <span class="project-title">{project.data.title}</span>
              {project.data.links && project.data.links.map((link: { type: string; url: string }) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" class="project-link">
                  [{link.type === "hf" ? "HuggingFace" : link.type}]
                </a>
              ))}
              {project.data.description && <span class="meta"> — {project.data.description}</span>}
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 16px;
    line-height: 1.6;
    color: #111;
    background: #fff;
    margin: 0;
    padding: 2rem 1rem;
  }

  main {
    max-width: 620px;
    margin: 0 auto;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  h1 {
    font-size: 1.6rem;
    font-weight: bold;
    margin: 0 0 0.25rem;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: bold;
    margin: 1.5rem 0 0.75rem;
  }

  .subtitle {
    margin: 0;
    color: #444;
  }

  .description {
    margin: 0 0 1rem;
  }

  .links {
    margin: 0 0 1rem;
  }

  hr {
    border: none;
    border-top: 1px solid #ddd;
    margin: 1.5rem 0;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    margin-bottom: 0.5rem;
  }

  a {
    color: #00e;
    text-decoration: underline;
  }

  a:visited {
    color: #551a8b;
  }

  .resume-btn {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border: 1px solid #aaa;
    border-radius: 3px;
    font-size: 0.9rem;
    color: #111;
    text-decoration: none;
    font-family: inherit;
  }

  .resume-btn:hover {
    background: #f0f0f0;
  }

  .project-title {
    font-weight: bold;
  }

  .project-link {
    margin-left: 0.4rem;
    font-size: 0.85rem;
  }

  .meta {
    color: #666;
    font-size: 0.9rem;
  }
</style>
