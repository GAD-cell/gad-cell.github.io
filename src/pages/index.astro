---
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../components/layout/BaseLayout.astro";

const siteConfig = await getEntry("site", "home");
if (!siteConfig) {
  throw new Error("Site configuration not found");
}

const site = siteConfig.data;

const posts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const latestPosts = posts
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
  )
  .slice(0, 3);

const experiences = await getCollection("experience");
const sortedExperiences = experiences.sort(
  (a: CollectionEntry<"experience">, b: CollectionEntry<"experience">) =>
    b.data.startDate.getTime() - a.data.startDate.getTime()
);

const papers = await getCollection("papers", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const latestPaper = papers.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())[0];
---

<BaseLayout title={`${site.name} - Portfolio`} description={site.introduction}>
  <div class="container">
    <section class="hero-section">
      <div class="profile-header">
        <img src="images/pp_pro.png" alt="Photo de moi" class="profile-photo" transition:name="profile-photo" />
        <div class="profile-info">
          <h1>{site.name}</h1>
          <p class="subtitle">{site.title}</p>
          <p class="introduction">{site.introduction}</p>
          {
            site.socialLinks && (
              <div class="social-links">
                {site.socialLinks.map(({ platform, url }) => (
                  <a href={url} target="_blank" rel="noopener noreferrer" class="social-link">
                    {platform}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
    </section>

    <section id="latest-paper" class="content-section">
      <div class="section-header">
        <h2>Latest Paper</h2>
        <a href="/papers" class="view-all">View All</a>
      </div>
      
      {latestPaper ? (
        <article class="paper-highlight">
            <div class="paper-content">
                <h3>{latestPaper.data.title}</h3>
                <div class="paper-meta">
                    {latestPaper.data.conference && <span class="conference-tag">{latestPaper.data.conference}</span>}
                    <span class="date">{latestPaper.data.publishedAt.getFullYear()}</span>
                </div>
                <p>{latestPaper.data.description}</p>
                <a href={latestPaper.data.pdfUrl} target="_blank" class="read-link">Read PDF →</a>
            </div>
        </article>
      ) : (
        <p>No papers published yet.</p>
      )}
    </section>

    <section id="latest-posts" class="content-section">
        <div class="section-header">
          <h2>Latest Writing</h2>
          <a href="/blog" class="view-all">View All</a>
        </div>
        <div class="stack">
          {latestPosts.map((post) => (
             <a href={`/blog/${post.id}`} class="card post-card">
                <div class="post-header">
                  <h3>{post.data.title}</h3>
                  <span class="date">{post.data.publishedAt.toLocaleDateString()}</span>
                </div>
                <p>{post.data.description}</p>
            </a>
          ))}
        </div>
    </section>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .hero-section {
    margin-bottom: 4rem;
    padding: 2rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .profile-photo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border-color);
  }

  .profile-info h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--text-color);
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .introduction {
    margin-bottom: 1.5rem;
    max-width: 500px;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
  }

  .social-link {
    padding: 0.4rem 0.8rem;
    background: var(--bg-color-muted);
    border-radius: 6px;
    font-size: 0.9rem;
    color: var(--text-color);
    transition: all 0.2s;
  }

  .social-link:hover {
    background: var(--border-color);
  }

  .content-section {
    margin-bottom: 4rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-color);
    background: none;
    -webkit-text-fill-color: initial;
  }

  .view-all {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: all 0.2s;
  }

  .view-all:hover {
    text-decoration-color: currentColor;
    color: var(--text-color);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card {
    display: block;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    transition: all var(--transition-base);
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    border-color: #000000;
    background: var(--hover-bg);
    box-shadow: var(--shadow-sm);
  }

  .card h3 {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    background: none;
    -webkit-text-fill-color: initial;
    color: var(--text-color);
  }

  .card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 2px 6px;
    background: var(--bg-color-muted);
    border-radius: 4px;
    color: var(--text-muted);
  }

  .post-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .date {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .profile-header {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
    
    .social-links {
      justify-content: center;
    }
    
    .introduction {
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Paper Highlight Styles */
  .paper-highlight {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 2rem;
    transition: all var(--transition-base);
  }
  
  .paper-highlight:hover {
    border-color: #000000;
    background: var(--hover-bg);
    box-shadow: var(--shadow-sm);
  }

  .paper-highlight h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .paper-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .conference-tag {
    background: var(--bg-color-muted);
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 500;
  }

  .read-link {
    display: inline-block;
    margin-top: 1rem;
    font-weight: 500;
    color: var(--text-color);
  }
</style>
