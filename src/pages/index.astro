---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const posts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sortedPosts = posts.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const papers = await getCollection("papers", ({ data }: CollectionEntry<"papers">) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const sortedPapers = papers.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

const socialLinks = [
  { label: "GitHub", url: "https://github.com/GAD-cell" },
  { label: "LinkedIn", url: "https://www.linkedin.com/in/sinou%C3%A9-gad-98b7b324b/" },
  { label: "HuggingFace", url: "https://huggingface.co/GAD-cell" },
];

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short" });
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sinoué GAD</title>
    <meta name="description" content="Machine Learning Scientist" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <main>
      <h1>Sinoué GAD</h1>
      <p class="subtitle">Machine Learning Scientist · MTS Intern at Liquid AI (post-training)</p>

      <p class="description">
        <!-- TODO: add your description here -->
        <em style="color: #999;">[description placeholder]</em>
      </p>

      <p class="links">
        {socialLinks.map((link, i) => (
          <>
            <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
            {i < socialLinks.length - 1 && " · "}
          </>
        ))}
      </p>

      <hr />

      <section>
        <h2>Papers</h2>
        <ul>
          {sortedPapers.map((paper) => (
            <li>
              <a href={paper.data.pdfUrl} target="_blank" rel="noopener noreferrer">
                {paper.data.title}
              </a>
              {paper.data.conference && <span class="meta"> — {paper.data.conference}</span>}
              <span class="meta"> ({paper.data.publishedAt.getFullYear()})</span>
            </li>
          ))}
        </ul>
      </section>

      <hr />

      <section>
        <h2>Blog</h2>
        <ul>
          {sortedPosts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <span class="meta"> — {formatDate(post.data.publishedAt)}</span>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 16px;
    line-height: 1.6;
    color: #111;
    background: #fff;
    margin: 0;
    padding: 2rem 1rem;
  }

  main {
    max-width: 620px;
    margin: 0 auto;
  }

  h1 {
    font-size: 1.6rem;
    font-weight: bold;
    margin: 0 0 0.25rem;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: bold;
    margin: 1.5rem 0 0.75rem;
  }

  .subtitle {
    margin: 0 0 1rem;
    color: #444;
  }

  .description {
    margin: 0 0 1rem;
  }

  .links {
    margin: 0 0 1rem;
  }

  hr {
    border: none;
    border-top: 1px solid #ddd;
    margin: 1.5rem 0;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    margin-bottom: 0.5rem;
  }

  a {
    color: #00e;
    text-decoration: underline;
  }

  a:visited {
    color: #551a8b;
  }

  .meta {
    color: #666;
    font-size: 0.9rem;
  }
</style>
